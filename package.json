  },
  "dependencies": {
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251108.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.42.1"
  }
}
