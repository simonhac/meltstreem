{
  "name": "headwater",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply headwater --local",
    "db:migrate:remote": "wrangler d1 migrations apply headwater --remote",
    "test": "vitest run",
    "backfill:stations": "curl -fsS -X POST -H \"Authorization: Bearer ${REPLAY_KEY:?set REPLAY_KEY}\" https://feed.moofer.com/admin/backfill-stations"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "hono": "^4.10.7",
    "jose": "^6.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20251108.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.42.1"
  }
}
